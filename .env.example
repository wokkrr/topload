# Copy to .env (gitignored) and fill in as you get keys.
# With none set, `npm run ingest` runs the offline demo pipeline.

# FREE PATH — no keys needed: this alone switches ingest to live mode, pulling
# free TCGplayer market-price snapshots via pokemontcg.io (raw PKMN cards only,
# marked source='tcgplayer' with hardest confidence discount).
TOPLOAD_MODE=live

# PriceCharting — PRIMARY bootstrap price source (solds-derived, per-grade).
# Legendary sub ($49/mo): https://www.pricecharting.com/subscriptions
PRICECHARTING_API_KEY=

# PriceCharting CSV auto-download (zero-touch daily bulk import).
# On pricecharting.com/subscriptions click "API/Download", then right-click each
# category's CSV download button → Copy Link Address → paste here:
PC_CSV_URL_PKMN=
PC_CSV_URL_YGO=
PC_CSV_URL_OP=
# Import floors (tunable): keep cards with sales-volume ≥ 10 and loose ≥ $2
PC_MIN_VOLUME=10
PC_MIN_PRICE_CENTS=200

# Pokémon TCG API — free metadata (card universe). Optional; raises rate limits.
# Get: https://dev.pokemontcg.io
POKEMONTCG_API_KEY=

# eBay Browse API — live listings for the aggregator (build step 2), NOT solds.
# Get: https://developer.ebay.com (create app → production keyset)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay Partner Network — affiliate deep links (build step 2).
EPN_CAMPAIGN_ID=

# eBay Marketplace Insights — real solds; partner-gated, application required.
# Apply via developer.ebay.com "growth" track; slot exists in adapters/ebay.js.

# Helius — Solana RPC + parsed transactions (free tier: helius.dev).
# Powers the on-chain gacha sales indexer (self-collected raw solds).
HELIUS_API_KEY=

# Alchemy — Base + Polygon data (free tier: alchemy.com), Beezie + Courtyard indexing
ALCHEMY_API_KEY=
